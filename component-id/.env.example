# Copy this file to .env and fill in the real value. .env is gitignored.
# API key for the RUNTIME of the component-ID service (not a personal plan key;
# this is the service credential used at runtime).
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default in code: current vision-capable Claude model)
# COMPONENT_ID_MODEL=claude-opus-4-8

# Port for the service
PORT=7895
